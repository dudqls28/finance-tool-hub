# Google AdSense (웹 수익화)
# https://www.google.com/adsense 에서 발급
VITE_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# AdSense 광고 슬롯 ID (광고 단위 생성 후 각 슬롯 ID 입력)
VITE_ADSENSE_SLOT_RESULT=
VITE_ADSENSE_SLOT_MID=
VITE_ADSENSE_SLOT_RELATED=

# Google Analytics (GA4) 측정 ID
# https://analytics.google.com 에서 속성 > 데이터 스트림 > 측정 ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
